{
  "$schema": "https://turborepo.dev/schema.json",
  "ui": "tui",
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "inputs": ["$TURBO_DEFAULT$", ".env*"],
      "outputs": [".next/**", "!.next/cache/**"]
    },
    "lint": {
      "dependsOn": ["^lint"]
    },
    "check-types": {
      "dependsOn": ["^check-types"]
    },
    "dev": {
      "cache": false,
      "persistent": true
    },
    "db:generate": {
      "cache": true,
      "inputs": ["prisma/schema.prisma", "prisma/migrations/**/*.sql"],
      "outputs": ["node_modules/.prisma/**"],
      "env": ["DATABASE_URL"]
    },
    "db:push": {"cache": false, "env": ["DATABASE_URL"]},
    "db:migrate:dev": {"cache": false, "env": ["DATABASE_URL"]},
    "db:migrate:deploy": {"cache": false, "env": ["DATABASE_URL"]},
    "db:studio": {"cache": false, "env": ["DATABASE_URL"]}
  }
}
